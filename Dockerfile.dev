FROM golang:1.25

WORKDIR /usr/src/app

# Install air for live reload in development
RUN go install github.com/air-verse/air@latest

# pre-copy/cache go.mod for pre-downloading dependencies and only redownloading them in subsequent builds if they change
COPY go.mod go.sum ./
RUN go mod download && go mod verify

# Copy air configuration for Docker
COPY .air.docker.toml ./

# Copy source code
COPY . .

# Create tmp directory for air builds
RUN mkdir -p tmp

# Expose port (default Gin port)
EXPOSE 8080

# Use air for live reload with Docker-specific config
CMD ["air", "-c", ".air.docker.toml"]